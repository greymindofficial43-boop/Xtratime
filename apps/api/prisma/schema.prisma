generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  EDITOR
}

enum MenuItemType {
  INTERNAL
  CATEGORY
  EXTERNAL
}

enum MenuItemPlacement {
  MAIN
  MEGA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  articles     Article[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  color       String?   @default("#e10600")
  sortOrder   Int       @default(0)
  showInNav   Boolean   @default(false)
  navOrder    Int       @default(99)
  showOnHomepage Boolean @default(false)
  homepageOrder  Int     @default(99)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  articles    Article[]
  articleLinks ArticleCategory[]
  menuItems   MenuItem[]
  homeSections HomeSection[]
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  articles  ArticleTag[]
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  excerpt       String?
  content       String        @db.Text
  featuredImage String?
  videoUrl      String?
  status        ArticleStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  isTrending    Boolean       @default(false)
  viewCount     Int           @default(0)
  publishedAt   DateTime?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  authorId      String
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // Primary category — drives the article's URL (/<category>/<slug>).
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  // Full set of categories this article belongs to (incl. the primary one).
  categories    ArticleCategory[]
  tags          ArticleTag[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([deletedAt])
}

// Many-to-many: an article can appear under several categories. The primary
// category lives on Article.categoryId; these rows include it plus any extras.
model ArticleCategory {
  articleId  String
  categoryId String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
  @@index([categoryId])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

enum AdType {
  GOOGLE
  CUSTOM
  THIRD_PARTY
}

model Match {
  id            String   @id @default(cuid())
  source        String   @default("manual")
  externalId    String?
  sport         String
  league        String?
  title         String
  homeTeamName  String
  homeTeamLogo  String
  homeTeamScore String?
  awayTeamName  String
  awayTeamLogo  String
  awayTeamScore String?
  status        String   // 'live' | 'upcoming' | 'result'
  note          String?
  statusDetail  String?
  venue         String?
  details       Json?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([source, externalId])
}

model Advertisement {
  id          String   @id @default(cuid())
  title       String
  type        AdType   @default(CUSTOM)
  partnerName String?
  imageUrl    String?
  targetUrl   String?
  googleCode  String?  @db.Text
  slotId      String   // e.g. "sidebar", "header"
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id             String            @id @default(cuid())
  title          String
  href           String?
  type           MenuItemType      @default(INTERNAL)
  placement      MenuItemPlacement @default(MAIN)
  description    String?
  badge          String?
  icon           String?
  groupName      String?
  isVisible      Boolean           @default(true)
  opensInNewTab  Boolean           @default(false)
  sortOrder      Int               @default(0)
  categoryId     String?
  category       Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parentId       String?
  parent         MenuItem?         @relation("MenuItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       MenuItem[]        @relation("MenuItemHierarchy")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([placement, sortOrder])
  @@index([parentId, sortOrder])
}

// Admin-managed promo banners shown in the homepage "Promo Banner" block.
// Replaces the previously hard-coded NFL/NBA ESPN cards.
model Promo {
  id        String   @id @default(cuid())
  title     String
  label     String?  // small eyebrow tag, e.g. "NFL" or "Featured"
  imageUrl  String?
  href      String   // where the card links to
  emoji     String?
  openInNewTab Boolean @default(false)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

// Site-wide popup ad: an image that links somewhere, shown as a modal on the
// public site between an optional start/end date, with a close button.
model PopupAd {
  id           String    @id @default(cuid())
  title        String?   // internal label (admin only)
  imageUrl     String
  linkUrl      String    // where a click redirects
  openInNewTab Boolean   @default(true)
  enabled      Boolean   @default(true)
  startDate    DateTime? // null = no start bound
  endDate      DateTime? // null = no end bound
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sortOrder])
}

// Toggleable / reorderable / renamable homepage blocks, edited from the admin.
model HomeSection {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "top-stories", "trending", "espn-news"
  title     String           // editable heading shown on the homepage
  type      String   @default("SYSTEM") // SYSTEM | CUSTOM_CATEGORY
  categoryId String?
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  articleLimit Int    @default(6)
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([type, sortOrder])
  @@index([categoryId])
}
