generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  EDITOR
}

enum MenuItemType {
  INTERNAL
  CATEGORY
  EXTERNAL
}

enum MenuItemPlacement {
  MAIN
  MEGA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  articles     Article[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  color       String?   @default("#e10600")
  sortOrder   Int       @default(0)
  showInNav   Boolean   @default(false)
  navOrder    Int       @default(99)
  showOnHomepage Boolean @default(false)
  homepageOrder  Int     @default(99)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  articles    Article[]
  menuItems   MenuItem[]
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  articles  ArticleTag[]
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  excerpt       String?
  content       String        @db.Text
  featuredImage String?
  videoUrl      String?
  status        ArticleStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  isTrending    Boolean       @default(false)
  viewCount     Int           @default(0)
  publishedAt   DateTime?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  authorId      String
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tags          ArticleTag[]

  @@index([status, publishedAt])
  @@index([categoryId])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

enum AdType {
  GOOGLE
  CUSTOM
  THIRD_PARTY
}

model Match {
  id            String   @id @default(cuid())
  source        String   @default("manual")
  externalId    String?
  sport         String
  league        String?
  title         String
  homeTeamName  String
  homeTeamLogo  String
  homeTeamScore String?
  awayTeamName  String
  awayTeamLogo  String
  awayTeamScore String?
  status        String   // 'live' | 'upcoming' | 'result'
  note          String?
  statusDetail  String?
  venue         String?
  details       Json?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([source, externalId])
}

model Advertisement {
  id          String   @id @default(cuid())
  title       String
  type        AdType   @default(CUSTOM)
  partnerName String?
  imageUrl    String?
  targetUrl   String?
  googleCode  String?  @db.Text
  slotId      String   // e.g. "sidebar", "header"
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id             String            @id @default(cuid())
  title          String
  href           String?
  type           MenuItemType      @default(INTERNAL)
  placement      MenuItemPlacement @default(MAIN)
  description    String?
  badge          String?
  icon           String?
  groupName      String?
  isVisible      Boolean           @default(true)
  opensInNewTab  Boolean           @default(false)
  sortOrder      Int               @default(0)
  categoryId     String?
  category       Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parentId       String?
  parent         MenuItem?         @relation("MenuItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       MenuItem[]        @relation("MenuItemHierarchy")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([placement, sortOrder])
  @@index([parentId, sortOrder])
}
