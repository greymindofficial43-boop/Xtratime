# English edition — copy to .env.en on the VPS and fill in real values.
# .env.en is gitignored: never commit it (it would be dual-pushed to the public repo).

DATABASE_URL="postgresql://sports:CHANGE_ME@localhost:5432/sportskeeda_en?schema=public"
PORT=4001
JWT_SECRET="CHANGE_ME_long_random_secret_en"
JWT_EXPIRES_IN="7d"

# Comma-separated, no spaces. The English web + admin Vercel domains.
CORS_ORIGINS="https://english-web.vercel.app,https://english-admin.vercel.app"

# Admin login — set your own; used by `npm run prisma:seed` and `npm run set-admin`.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""

# External keys — use your own, rotated values.
CRICAPI_KEY=""
HIGHLIGHTLY_API_KEY=""

# Cloudinary — required for image uploads.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
