# Bangla edition — copy to .env.bn on the VPS and fill in real values.
# .env.bn is gitignored: never commit it (it would be dual-pushed to the public repo).

DATABASE_URL="postgresql://sports:CHANGE_ME@localhost:5432/sportskeeda?schema=public"
PORT=4000
JWT_SECRET="CHANGE_ME_long_random_secret_bn"
JWT_EXPIRES_IN="7d"

# Comma-separated, no spaces. The Bangla web + admin Vercel domains.
CORS_ORIGINS="https://bangla-web.vercel.app,https://bangla-admin.vercel.app"

# Admin login — set your own; used by `npm run prisma:seed` and `npm run set-admin`.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME=""

# External keys — use your own, rotated values.
CRICAPI_KEY=""
HIGHLIGHTLY_API_KEY=""

# Cloudinary — required for image uploads.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Image Watermark Logo (path relative to repo root)
WATERMARK_LOGO="LOGO BANGLA .png"
